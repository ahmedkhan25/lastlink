# LastLink — environment template. Copy to .env and fill in.
# .env and *.env are gitignored; .env.example is committed.

# ── Database (Neon) ─────────────────────────────────────────────
# Pooled URL for the app/runtime; direct URL for migrations + Hasura engine.
DATABASE_URL="postgres://USER:PASS@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_DIRECT="postgres://USER:PASS@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Hasura ──────────────────────────────────────────────────────
HASURA_GRAPHQL_ADMIN_SECRET="<openssl rand -hex 24>"
# Endpoint the API proxies to (local Docker default):
HASURA_GRAPHQL_ENDPOINT="http://localhost:8080/v1/graphql"

# ── Auth (Better Auth) ──────────────────────────────────────────
BETTER_AUTH_SECRET="<openssl rand -hex 32>"
API_BASE_URL="http://localhost:10000"
APP_BASE_URL="http://localhost:5273"
# Comma-separated dev origins allowed by CORS + Better Auth:
APP_ORIGINS="http://localhost:5273,http://127.0.0.1:5273"

# ── Letter encryption (local AES; KMS deferred) ─────────────────
LETTER_ENC_KEY="<openssl rand -hex 32>"   # 32 bytes / 64 hex chars

# ── Mux (video) — token id/secret may live in a separate mux env file ──
MUX_TOKEN_ID=""
MUX_TOKEN_SECRET=""
MUX_WEBHOOK_SECRET=""                      # set when wiring /webhooks/mux (prod)
MUX_SIGNING_KEY_ID=""                       # created via apps/api/create-signing-key.ts
MUX_SIGNING_KEY_PRIVATE=""                  # base64 PEM (signed playback)
# MUX_CORS_ORIGIN="http://localhost:5273"   # exact origin in prod; defaults to * in dev

# ── Resend (email) — pending ────────────────────────────────────
RESEND_API_KEY=""

# ── Demo controls ───────────────────────────────────────────────
# HOLD_DURATION_MS=120000   # time-warp the 24h hold for live demos (default 24h)
